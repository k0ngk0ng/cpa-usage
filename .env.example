# --- CPA connection ---
CPA_BASE_URL=http://127.0.0.1:8317
CPA_MANAGEMENT_KEY=replace-with-your-management-key
CPA_LOG_DIR=/home/cliproxy/cliproxyapi/logs
# Per-section caps for the parsed log view (Events → Log modal). The raw
# endpoint is unaffected. Defaults: 8 MiB body, 64 KiB headers.
LOG_BODY_MAX_BYTES=8388608
LOG_HEADER_MAX_BYTES=65536

# --- HTTP server ---
APP_PORT=8318
# Subpath; "" means root. Default is /usage.
APP_BASE_PATH=/usage

# Business timezone. Affects "today" boundary, daily aggregation, daily 03:00 cleanup, and log timestamps.
TZ=Asia/Shanghai

# --- Storage ---
# Currently only sqlite is implemented. Reserved for future mysql / postgres / clickhouse.
STORAGE_DRIVER=sqlite
SQLITE_PATH=/home/cliproxy/cpa-usage/data/app.db

# --- Redis queue (CPA usage stream) ---
# host:port. Default: derived from CPA_BASE_URL host + 8317.
REDIS_QUEUE_ADDR=
# RESP channel. CPA v7+ expects "usage"; v6.10 ignores the key.
REDIS_QUEUE_KEY=usage
REDIS_QUEUE_BATCH_SIZE=1000
REDIS_QUEUE_IDLE_INTERVAL=1s
REDIS_QUEUE_ERROR_BACKOFF=10s

# --- Metadata sync ---
METADATA_SYNC_INTERVAL=30s
REQUEST_TIMEOUT=30s

# --- Authentication ---
AUTH_ENABLED=false
LOGIN_PASSWORD=
AUTH_SESSION_TTL=168h

# --- Logging ---
LOG_LEVEL=info
LOG_FILE_ENABLED=true
# Relative to the working directory (systemd: /home/user/cpa-usage).
LOG_DIR=/home/cliproxy/cpa-usage/logs
LOG_RETENTION_DAYS=7
